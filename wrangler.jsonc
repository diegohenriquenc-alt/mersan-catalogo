{
  "name": "mersan-catalogo",
  "compatibility_date": "2026-07-01",
  "main": "worker/index.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true,
    "not_found_handling": "single-page-application"
  },
  "kv_namespaces": [
    {
      "binding": "FOTOS",
      "id": "9fbce68725ad4ddca090caa0c8dcb473"
    }
  ],
  "triggers": {
    "crons": ["*/5 * * * *"]
  }
}

